{
  "expo": {
    "name": "FutureControl",
    "slug": "futurecontrol",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "futurecontrol",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.futurecontrol.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "FutureControl uses the microphone for voice commands"
      }
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#0a0a0a" },
      "edgeToEdgeEnabled": true,
      "package": "com.futurecontrol.app",
      "permissions": ["RECORD_AUDIO", "VIBRATE"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-av", { "microphonePermission": "FutureControl needs microphone access for voice commands." }],
      "./plugins/withTapService"
    ]
  }
}
